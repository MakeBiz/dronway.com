---
const { eyebrow, title, lead, crumbs = [] } = Astro.props;
---
<section class="pagehead">
  <div class="glow"></div>
  <div class="wrap">
    {crumbs.length > 0 && (
      <div class="crumbs">
        <a href="/">Главная</a>
        {crumbs.map((c) => (
          <span><span class="sep">/</span>{c.href ? <a href={c.href}>{c.label}</a> : <span class="cur">{c.label}</span>}</span>
        ))}
      </div>
    )}
    {eyebrow && <div class="eyebrow ph-eyebrow">{eyebrow}</div>}
    <h1>{title}</h1>
    {lead && <p class="ph-lead">{lead}</p>}
  </div>
</section>
