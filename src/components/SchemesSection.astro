---
// SchemesSection.astro - сравнение С нами vs Без нас на главной
const usSteps = [
  { icon: 'drone',  cat: 'ЗАДАЧА + ПОДБОР',       title: 'Разбираемся в вашей задаче', desc: 'Подбираем борт под груз, маршрут и условия, не по каталогу' },
  { icon: 'doc',    cat: 'ДОКУМЕНТЫ',              title: 'Все регуляторные шаги на нас', desc: 'Учёт, регистрация, лётная годность без вашего участия' },
  { icon: 'fly',    cat: 'ПОСТАВКА + ЗАПУСК',      title: 'Доставляем и запускаем', desc: 'Поставка, настройка, обучение пилота и первый рабочий вылет' },
  { icon: 'shield', cat: 'СЕРВИС',                 title: 'Поддержка после запуска', desc: 'Запчасти, ТО, консультации на всём сроке эксплуатации' },
];
const withoutSteps = [
  'Самостоятельный поиск поставщика',
  'Изучение технических характеристик',
  'Запросы коммерческих предложений',
  'Сравнение и анализ вариантов',
  'Принятие решения о покупке',
  'Оформление договора',
  'Получение и проверка поставки',
  'Разбор регуляторных требований',
  'Поиск учебного центра для пилота',
  'Самостоятельный запуск в работу',
  'Поиск сервиса при поломке',
];
---

<section class="schemes-section">
  <div class="wrap">
    <div class="eyebrow">Сравнение</div>
    <h2 class="h">С нами или самостоятельно</h2>
    <p class="lead">Разница в количестве шагов говорит сама за себя</p>

    <div class="schemes-grid">

      <!-- Левая: С нами, 4 шага -->
      <div class="sc-col sc-us">
        <div class="sc-head sc-head-blue">
          <span class="sc-count">4 шага</span>
          <span class="sc-label">С нами</span>
        </div>

        {usSteps.map((s) => (
          <div class="sc-item sc-item-blue">
            <div class="sc-icon-wrap sc-icon-blue">
              {s.icon === 'drone' && (
                <svg width="28" height="28" viewBox="0 0 56 56" fill="none">
                  <line x1="28" y1="28" x2="8" y2="28" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="28" y1="28" x2="48" y2="28" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="28" y1="28" x2="28" y2="8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="28" y1="28" x2="28" y2="48" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                  <circle cx="28" cy="28" r="6" fill="rgba(255,255,255,.2)" stroke="white" stroke-width="2"/>
                  <ellipse cx="8" cy="28" rx="6" ry="3" fill="rgba(255,255,255,.45)"/>
                  <ellipse cx="48" cy="28" rx="6" ry="3" fill="rgba(255,255,255,.45)"/>
                  <ellipse cx="28" cy="8" rx="3" ry="6" fill="rgba(255,255,255,.45)"/>
                  <ellipse cx="28" cy="48" rx="3" ry="6" fill="rgba(255,255,255,.45)"/>
                </svg>
              )}
              {s.icon === 'doc' && (
                <svg width="28" height="28" viewBox="0 0 56 56" fill="none">
                  <rect x="10" y="8" width="22" height="28" rx="2" fill="rgba(255,255,255,.15)" stroke="rgba(255,255,255,.5)" stroke-width="1.5"/>
                  <rect x="6" y="4" width="22" height="28" rx="2" fill="rgba(255,255,255,.2)" stroke="white" stroke-width="2"/>
                  <line x1="11" y1="12" x2="23" y2="12" stroke="white" stroke-width="1.5" opacity=".8"/>
                  <line x1="11" y1="17" x2="23" y2="17" stroke="white" stroke-width="1.5" opacity=".8"/>
                  <line x1="11" y1="22" x2="18" y2="22" stroke="white" stroke-width="1.5" opacity=".8"/>
                  <circle cx="38" cy="40" r="11" fill="rgba(255,255,255,.95)"/>
                  <polyline points="32,40 36,44 44,35" stroke="#0E3FA8" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {s.icon === 'fly' && (
                <svg width="28" height="28" viewBox="0 0 56 56" fill="none">
                  <line x1="22" y1="28" x2="8" y2="28" stroke="white" stroke-width="2" stroke-linecap="round"/>
                  <line x1="22" y1="28" x2="36" y2="28" stroke="white" stroke-width="2" stroke-linecap="round"/>
                  <line x1="22" y1="28" x2="22" y2="14" stroke="white" stroke-width="2" stroke-linecap="round"/>
                  <line x1="22" y1="28" x2="22" y2="42" stroke="white" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="22" cy="28" r="5" fill="rgba(255,255,255,.2)" stroke="white" stroke-width="2"/>
                  <ellipse cx="8" cy="28" rx="6" ry="3" fill="rgba(255,255,255,.4)"/>
                  <ellipse cx="36" cy="28" rx="6" ry="3" fill="rgba(255,255,255,.4)"/>
                  <ellipse cx="22" cy="14" rx="3" ry="6" fill="rgba(255,255,255,.4)"/>
                  <ellipse cx="22" cy="42" rx="3" ry="6" fill="rgba(255,255,255,.4)"/>
                  <line x1="38" y1="28" x2="50" y2="28" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
                  <polyline points="44,22 50,28 44,34" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
              {s.icon === 'shield' && (
                <svg width="28" height="28" viewBox="0 0 56 56" fill="none">
                  <path d="M28 8 L46 15 L46 30 Q46 44 28 50 Q10 44 10 30 L10 15 Z" fill="rgba(255,255,255,.15)" stroke="white" stroke-width="2"/>
                  <polyline points="20,28 25,34 36,22" stroke="white" stroke-width="3.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </div>
            <div class="sc-text">
              <div class="sc-cat">{s.cat}</div>
              <div class="sc-title">{s.title}</div>
              <div class="sc-desc">{s.desc}</div>
            </div>
          </div>
        ))}

        <div class="sc-footer sc-footer-green">
          Быстро · Понятно · Рабочий результат
        </div>
      </div>

      <!-- Правая: Без нас, 11 шагов -->
      <div class="sc-col sc-without">
        <div class="sc-head sc-head-gray">
          <span class="sc-count">11 шагов</span>
          <span class="sc-label">Без нас</span>
        </div>

        {withoutSteps.map((s, i) => (
          <div class="sc-item sc-item-red">
            <div class="sc-icon-wrap sc-icon-red">
              <span class="sc-num">{i + 1}</span>
            </div>
            <div class="sc-text">
              <div class="sc-title sc-title-sm">{s}</div>
            </div>
          </div>
        ))}

        <div class="sc-footer sc-footer-warn">
          11 шагов · Риск ошибки · Потеря времени и денег
        </div>
      </div>

    </div>

    <p class="schemes-note">Точный набор шагов зависит от класса борта и вашей ситуации, суть остаётся: с нами один договор, с нас весь путь</p>
  </div>
</section>

<style>
.schemes-section { padding: 84px 0; background: var(--white); }

.schemes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-top: 48px;
  align-items: start;
}

/* Колонки */
.sc-col { display: flex; flex-direction: column; gap: 0; }

.sc-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 20px; border-radius: 8px 8px 0 0;
  margin-bottom: 2px;
}
.sc-head-blue { background: #15181C; }
.sc-head-gray { background: #2D3748; }

.sc-count {
  font-family: 'Montserrat', sans-serif;
  font-size: 22px; font-weight: 800; color: #fff;
}
.sc-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 11px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: rgba(255,255,255,.5);
}

/* Карточки-шаги */
.sc-item {
  display: flex; align-items: center; gap: 14px;
  padding: 10px 14px; border-bottom: 1px solid #F0F2F5;
}
.sc-item:nth-child(even) { background: #FAFBFC; }
.sc-item:last-of-type { border-radius: 0 0 8px 8px; border-bottom: none; }

.sc-item-blue { border-left: 3px solid #1E63E9; }
.sc-item-red  { border-left: 3px solid #DC2626; }

/* Иконки */
.sc-icon-wrap {
  flex-shrink: 0; width: 52px; height: 52px;
  border-radius: 6px; display: flex; align-items: center; justify-content: center;
}
.sc-icon-blue { background: #1E63E9; }
.sc-icon-red  { background: #DC2626; }

.sc-num {
  font-family: 'Montserrat', sans-serif;
  font-size: 16px; font-weight: 800; color: rgba(255,255,255,.9);
}

/* Текст */
.sc-cat {
  font-family: 'Montserrat', sans-serif;
  font-size: 9px; font-weight: 700; letter-spacing: 2px;
  color: #9CA3AF; text-transform: uppercase; margin-bottom: 3px;
}
.sc-title {
  font-size: 14px; font-weight: 700; color: #111827; margin-bottom: 3px; line-height: 1.3;
}
.sc-title-sm { font-size: 13px; margin-bottom: 0; }
.sc-desc { font-size: 11px; color: #6B7280; line-height: 1.4; }

/* Footer */
.sc-footer {
  margin-top: 8px; padding: 12px 18px;
  border-radius: 6px; font-size: 13px; font-weight: 600;
  text-align: center; letter-spacing: .2px;
}
.sc-footer-green { background: #DCFCE7; color: #14532D; border: 1px solid #16A34A; }
.sc-footer-warn  { background: #FEF3C7; color: #78350F; border: 1px solid #D97706; }

.schemes-note {
  margin-top: 32px; font-size: 13px; color: var(--muted);
  text-align: center; max-width: 640px; margin-left: auto; margin-right: auto;
}

@media (max-width: 680px) {
  .schemes-grid { grid-template-columns: 1fr; }
}
</style>
