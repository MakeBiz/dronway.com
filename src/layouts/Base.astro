---
import '../styles/global.css';
import { site } from '../data/site.js';
const { title, description = 'DronWay, дроны под ключ: подбор, поставка, документы, эксплуатация, страхование и партнёрство', active = '' } = Astro.props;
const fullTitle = title ? `${title} · DronWay` : 'DronWay, дроны под ключ';
const drone = `<svg width="40" height="40" viewBox="0 0 120 120" aria-hidden="true"><g stroke-linecap="round" transform="translate(-25,-18)"><g stroke="#fff" stroke-width="7"><line x1="85" y1="70" x2="61" y2="46"/><line x1="85" y1="70" x2="109" y2="46"/><line x1="85" y1="70" x2="61" y2="94"/><line x1="85" y1="70" x2="109" y2="94"/></g><circle cx="61" cy="46" r="13" fill="none" stroke="#fff" stroke-width="4"/><circle cx="109" cy="46" r="13" fill="none" stroke="#1E63E9" stroke-width="4"/><circle cx="61" cy="94" r="13" fill="none" stroke="#fff" stroke-width="4"/><circle cx="109" cy="94" r="13" fill="none" stroke="#fff" stroke-width="4"/><rect x="73" y="58" width="24" height="24" rx="7" fill="#fff"/></g></svg>`;
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="hd">
    <div class="wrap bar">
      <a class="logo" href="/" aria-label="DronWay">
        <Fragment set:html={drone} />
        <span class="nm">Dron<b>Way</b></span>
      </a>
      <nav class="nav" id="menu">
        {site.nav.map((n) => (
          <a href={n.href} class={active === n.href ? 'active' : ''}>{n.label}</a>
        ))}
        <a href="/contacts" class="btn">Получить расчёт</a>
      </nav>
      <div class="burger" id="burger" aria-label="Меню"><span></span><span></span><span></span></div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="ft">
    <div class="wrap">
      <div class="cols">
        <div>
          <a class="logo" href="/"><Fragment set:html={drone} /><span class="nm">Dron<b>Way</b></span></a>
          <p style="color:#9AA3B0;font-size:14px;margin-top:14px;max-width:320px;">Единый интегратор по дронам: подбираем технику у разных поставщиков и берём на себя весь путь от завода до легальных полётов.</p>
        </div>
        <div>
          <h4>Разделы</h4>
          {site.footer.slice(0,5).map((f) => (<a href={f.href}>{f.label}</a>))}
        </div>
        <div>
          <h4>Ещё</h4>
          {site.footer.slice(5).map((f) => (<a href={f.href}>{f.label}</a>))}
        </div>
      </div>
      <div class="bottom">
        <span>DronWay · {site.domain}</span>
        <span>Поставка · документы · эксплуатация · страхование · партнёрство</span>
      </div>
    </div>
  </footer>

  <script>
    const b = document.getElementById('burger');
    const m = document.getElementById('menu');
    if (b && m) b.addEventListener('click', () => m.classList.toggle('open'));
  </script>
</body>
</html>
