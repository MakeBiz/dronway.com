---
// Site.astro - layout дизайн-системы прототипа (Moxion-style, светлая тема).
// Изолирован от старого global.css: стили заданы локально через <style is:global>,
// поэтому не влияет на страницы, которые ещё используют Base.astro.
const {
  title = '',
  description = 'DronWay - грузовые беспилотники от 10 до 150 кг под ключ: подбор, поставка, документы и легальные полёты.',
  active = '',
} = Astro.props;
const fullTitle = title ? `${title} · DronWay` : 'DronWay - грузовые беспилотники под ключ';

const nav = [
  { label: 'Каталог', href: '/catalog' },
  { label: 'Услуги', href: '/services' },
  { label: 'Кейсы', href: '/cases' },
  { label: 'Этапы', href: '/process' },
];
const footerLinks = [
  { label: 'Каталог', href: '/catalog' },
  { label: 'Услуги', href: '/services' },
  { label: 'Этапы работы', href: '/process' },
  { label: 'Кейсы', href: '/cases' },
  { label: 'О нас', href: '/about' },
  { label: 'Контакты', href: '/contacts' },
];
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Space+Grotesk:wght@300;500;700&display=swap" rel="stylesheet" />
</head>
<body>
  <nav id="nav" class="x-nav">
    <a class="x-logo" href="/"><img src="/logo.svg" alt="DronWay" width="116" height="31" /></a>
    <div class="x-nav-links">
      {nav.map((n) => (
        <a href={n.href} class={active === n.href ? 'active' : ''}>{n.label}</a>
      ))}
      <a href="/contacts" class="x-cta-m">Запросить расчёт</a>
    </div>
    <a class="x-nav-cta" href="/contacts">Запросить расчёт</a>
    <div class="x-burger" id="burger"><span></span><span></span><span></span></div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="x-footer">
    <img class="fl-logo" src="/logo.svg" alt="DronWay" width="100" height="27" />
    <span class="fm">Россия, Ярославль - производство DRONAX - 2026</span>
    <span class="fr"><a href="/contacts">dronway.com</a></span>
  </footer>

  <nav class="x-footnav">
    {footerLinks.map((f) => (<a href={f.href}>{f.label}</a>))}
  </nav>

  <script>
    const nav = document.getElementById('nav');
    if (nav) {
      const onScroll = () => {
        if (window.scrollY > 40) nav.classList.add('scrolled');
        else nav.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
    const burger = document.getElementById('burger');
    if (burger && nav) burger.addEventListener('click', () => nav.classList.toggle('open'));

    const io = new IntersectionObserver((es) => {
      es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal, .stage-img').forEach((el) => io.observe(el));
  </script>

  <style is:global>
    :root{
      --bg:#FAFBFD; --w:#FFFFFF; --ink:#0E1420; --mu:#697483; --mul:#9AA8B8;
      --bl:#1E63E9; --surf:#F0F4FA; --line:#E2E8EF; --gold:#C9A84C; --dark:#0B0F17;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--ink);font-family:Inter,system-ui,sans-serif;overflow-x:hidden;line-height:1.5;-webkit-font-smoothing:antialiased}
    a{text-decoration:none;color:inherit}
    img{display:block;max-width:100%}
    button{cursor:pointer;font-family:inherit}
    .sg{font-family:'Space Grotesk',sans-serif}

    @keyframes up{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}
    .reveal{opacity:0;transform:translateY(24px);transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1)}
    .reveal.in{opacity:1;transform:none}
    .stage-img{opacity:0;transform:scale(1.05);transition:opacity 1s cubic-bezier(.16,1,.3,1),transform 1.3s cubic-bezier(.16,1,.3,1)}
    .stage-img.in{opacity:1;transform:scale(1)}
    .h1a{animation:up 1s cubic-bezier(.16,1,.3,1) .15s both}
    .h1b{animation:up 1s cubic-bezier(.16,1,.3,1) .38s both}
    .hsub{animation:up 1s cubic-bezier(.16,1,.3,1) .58s both}
    .hbtn{animation:up 1s cubic-bezier(.16,1,.3,1) .72s both}
    .hst{animation:up 1s cubic-bezier(.16,1,.3,1) .88s both}
    .himg{animation:up 1.2s cubic-bezier(.16,1,.3,1) .3s both}

    /* nav */
    .x-nav{position:fixed;top:0;left:0;right:0;z-index:100;height:60px;padding:0 clamp(22px,4vw,48px);
      display:flex;align-items:center;justify-content:space-between;background:transparent;transition:all .35s}
    .x-nav.scrolled{background:rgba(250,251,253,.94);backdrop-filter:blur(20px);border-bottom:1px solid var(--line)}
    .x-logo{font-family:'Space Grotesk';font-weight:700;font-size:14px;letter-spacing:4px;color:var(--ink)}
    .x-logo img{height:30px;width:auto;display:block}
    .x-footer .fl-logo{height:26px;width:auto;display:block}
    .x-nav-links{display:flex;gap:36px}
    .x-nav-links a{color:var(--mu);font-size:14px;font-weight:500;padding:8px 2px;transition:color .2s}
    .x-nav-links a:hover,.x-nav-links a.active{color:var(--ink)}
    .x-nav-cta{background:var(--bl);color:#fff;padding:9px 22px;border-radius:6px;font-size:12px;font-weight:700;transition:background .2s}
    .x-nav-cta:hover{background:#1855cc}
    .x-cta-m{display:none}
    .x-burger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:6px}
    .x-burger span{width:22px;height:2px;background:var(--ink);border-radius:2px}

    /* footer */
    .x-footer{padding:28px clamp(22px,4vw,48px);background:var(--w);border-top:1px solid var(--line);
      display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
    .x-footer .fl{font-family:'Space Grotesk';font-weight:700;font-size:12px;letter-spacing:4px;color:var(--mul)}
    .x-footer .fm{font-size:11px;color:var(--mul)}
    .x-footer .fr a{font-size:11px;color:var(--bl)}
    .x-footnav{background:var(--w);padding:0 clamp(22px,4vw,48px) 30px;display:flex;flex-wrap:wrap;gap:18px 26px;border-bottom:none}
    .x-footnav a{font-size:12px;color:var(--mu);transition:color .2s}
    .x-footnav a:hover{color:var(--bl)}

    @media (max-width:900px){
      .x-nav-links{display:none;position:absolute;top:60px;left:0;right:0;flex-direction:column;align-items:stretch;
        background:rgba(250,251,253,.98);backdrop-filter:blur(20px);padding:14px 22px 20px;gap:4px;border-bottom:1px solid var(--line)}
      .x-nav.open .x-nav-links{display:flex}
      .x-nav-links a{font-size:16px;padding:12px 4px}
      .x-cta-m{display:none}
      .x-nav-cta{margin-left:auto;padding:10px 16px;font-size:12px;background:#1E63E9;color:#fff}
      .x-burger{display:flex;margin-left:12px;border:1px solid #D7DEE7;border-radius:8px;padding:8px 9px;background:#fff}
      .x-burger span{background:#0E1420}
    }
    @media (prefers-reduced-motion: reduce){
      *{animation:none !important}
      .reveal,.stage-img{transition:none !important;opacity:1 !important;transform:none !important}
    }
  </style>
</body>
</html>
