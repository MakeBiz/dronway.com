---
import Base from '../layouts/Base.astro';
import PageHead from '../components/PageHead.astro';
import CtaBand from '../components/CtaBand.astro';
const cards = [
  ['СВИДЕТЕЛЬСТВО','Внешний пилот','Теория, тренажёр и лётная практика по программе аккредитованного учебного центра'],
  ['ПОД ВАШ ПАРК','Операторы клиента','Готовим пилотов под конкретные борта и сценарии вашей работы'],
  ['ПОДДЕРЖКА','Ресертификация','Поддерживаем квалификацию по мере изменения правил и техники'],
];
---
<Base title="Обучение пилотов" description="Обучение внешних пилотов БПЛА через аккредитованный учебный центр, под ваши борта и задачи" active="">
  <PageHead eyebrow="Обучение" title="Подготовка внешних пилотов"
    lead="Если идёте своим парком по модели со своим бортом, готовим ваших операторов и помогаем получить свидетельство внешнего пилота через аккредитованный учебный центр"
    crumbs={[{label:'Обучение'}]} />
  <section class="sec white">
    <div class="wrap">
      <div class="grid g3" style="margin-top:0;">
        {cards.map(([n,t,d]) => (<div class="card"><div class="n">{n}</div><h3>{t}</h3><p>{d}</p></div>))}
      </div>
      <div style="margin-top:46px;"><CtaBand title="Обучить операторов" text="Расскажите про парк и задачи, подберём программу подготовки" /></div>
    </div>
  </section>
</Base>
