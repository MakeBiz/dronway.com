---
import Base from '../../layouts/Base.astro';
import PageHead from '../../components/PageHead.astro';
import { applications } from '../../data/applications.js';
export function getStaticPaths() {
  return applications.map((a) => ({ params: { slug: a.slug }, props: { a } }));
}
const { a } = Astro.props;
const others = applications.filter((x) => x.slug !== a.slug).slice(0, 4);
---
<Base title={a.name} description={`${a.name}. ${a.short}`} active="/applications">
  <PageHead eyebrow={`Применение · ${a.tag}`} title={a.name} lead={a.short}
    crumbs={[{label:'Применение', href:'/applications'}, {label:a.name}]} />
  <section class="sec white">
    <div class="wrap">
      <div class="detail">
        <div>
          <div class="eyebrow">Задача</div>
          <p style="font-size:16px;color:var(--muted);margin-top:14px;line-height:1.6;">{a.desc}</p>
          <div class="eyebrow" style="margin-top:32px;">Что делаем</div>
          <ul class="flist" style="margin-top:16px;">{a.work.map((w) => (<li>{w}</li>))}</ul>
        </div>
        <div>
          <div class="spec" style="padding:22px;">
            <div class="eyebrow">Чем закрываем</div>
            <p style="font-size:15.5px;margin-top:10px;line-height:1.55;color:var(--muted);">{a.kit}</p>
          </div>
          <a href="/contacts" class="btn lg" style="margin-top:18px;width:100%;">Заказать работы</a>
          <a href="/catalog" class="btn lg ghost" style="margin-top:12px;width:100%;color:var(--ink);border-color:var(--line);">Смотреть технику</a>
        </div>
      </div>
    </div>
  </section>
  <section class="sec">
    <div class="wrap">
      <div class="eyebrow">Другие применения</div>
      <h2 class="h" style="font-size:28px;">Закрываем разные отрасли</h2>
      <div class="grid g4">
        {others.map((o) => (
          <a class="card" href={`/applications/${o.slug}`}><div class="n">{o.tag.toUpperCase()}</div><h3 style="font-size:18px;">{o.name}</h3><p>{o.short}</p></a>
        ))}
      </div>
    </div>
  </section>
</Base>
