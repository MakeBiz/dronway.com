---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';
import DroneLineup from '../components/DroneLineup.astro';
import SchemesSection from '../components/SchemesSection.astro';
import { services } from '../data/services.js';
import { applications } from '../data/applications.js';
import { drones } from '../data/drones.js';
const why = [
  ['01','Мультивендор','Не привязаны к одному производителю, берём лучший борт под вашу задачу'],
  ['02','Весь путь под ключ','От подбора и поставки до легальных полётов, всё в одних руках'],
  ['03','Единая ответственность','Один договор и один ответственный за результат, а не цепочка подрядчиков'],
  ['04','Документы и годность','Учёт, госрегистрация, лётная годность и сертификат эксплуатанта оформляем мы'],
  ['05','Страхование','Оформляем страховку и работаем со страховщиками под ваши полёты'],
  ['06','Дрон как сервис','Можно без своего сертификата и пилота, вы платите за результат'],
  ['07','Партнёрская модель','Реферал, работа в регионе с делением выручки, борта на спеццене'],
  ['08','Прозрачная экономика','Считаем стоимость вылета и окупаемость маршрута заранее'],
];
const cargo = drones.slice(0,4);
---
<Base title="" description="DronWay, дроны под ключ: подбор у разных поставщиков, поставка, документы, эксплуатация, страхование и партнёрство" active="/">

  <!-- HERO с видео-фоном ЧК-9 -->
  <section class="hero hero-video">
    <div class="hero-bg">
      <video autoplay muted loop playsinline poster="/images/ck9.jpg" class="hero-vid">
        <source src="/video/ck9.mp4" type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
    </div>
    <div class="wrap hero-wrap">
      <div class="eyebrow" style="color:#6BA0FF;">Дроны под ключ</div>
      <h1>От завода до легального полёта, всё в одних руках</h1>
      <p>DronWay это единый интегратор по дронам. Подбираем технику у разных производителей, поставляем, оформляем документы, держим эксплуатацию, страхуем и развиваем партнёров. Вы получаете не коробку, а готовое решение под задачу.</p>
      <div class="cta">
        <a href="/contacts" class="btn lg">Получить расчёт</a>
        <a href="/catalog" class="btn lg ghost">Смотреть каталог</a>
      </div>
      <div class="path"><div class="dot"></div><div class="seg"></div><div class="dot"></div><div class="seg"></div><div class="dot"></div><div class="seg"></div><div class="dot"></div><div class="seg"></div><div class="dot end"></div></div>
    </div>
  </section>

  <!-- ЛИНЕЙКА БОРТОВ — три панели с фото -->
  <DroneLineup />

  <!-- КАТАЛОГ -->
  <section class="sec white">
    <div class="wrap">
      <div class="eyebrow">Каталог</div>
      <h2 class="h">Грузовая линейка DW, от 10 до 150 кг</h2>
      <p class="lead">Грузовые мультироторы под доставку и снабжение. Порог 30 кг делит технику на лёгкий и тяжёлый путь по документам</p>
      <div class="grid g4">
        {cargo.map((d) => (
          <a class="card" href={`/catalog/${d.slug}`}>
            <div class="n">{d.frame.toUpperCase()}</div>
            <h3>{d.name}</h3>
            <p>{d.payload} кг · {d.flight} мин</p>
            <span class="more">Подробнее →</span>
          </a>
        ))}
      </div>
      <div style="margin-top:26px;"><a href="/catalog" class="btn">Весь каталог и виды дронов</a></div>
    </div>
  </section>

  <!-- СХЕМЫ: С нами / Без нас -->
  <SchemesSection />

  <!-- УСЛУГИ -->
  <section class="sec">
    <div class="wrap">
      <div class="eyebrow">Услуги</div>
      <h2 class="h">Восемь услуг, которые закрывают весь цикл</h2>
      <div class="grid g4">
        {services.map((s) => (
          <a class="card" href={`/services/${s.slug}`}>
            <div class="n">{s.icon}</div>
            <h3 style="font-size:18px;">{s.name}</h3>
            <p>{s.short}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ПРИМЕНЕНИЕ -->
  <section class="sec dark">
    <div class="wrap">
      <div class="eyebrow" style="color:#6BA0FF;">Применение</div>
      <h2 class="h">Что обследуем, снимаем и возим</h2>
      <div class="grid g4">
        {applications.map((a) => (
          <a class="card" href={`/applications/${a.slug}`}>
            <div class="n">{a.tag.toUpperCase()}</div>
            <h3 style="font-size:18px;">{a.name}</h3>
            <p>{a.short}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ПОЧЕМУ МЫ -->
  <section class="sec white">
    <div class="wrap">
      <div class="eyebrow">Почему DronWay</div>
      <h2 class="h">Полный пакет под ключ, какого нет у одного игрока сразу</h2>
      <p class="lead">На рынке кто-то делает только съёмку, кто-то только документы, кто-то только продаёт борта. Мы собираем весь цикл в одну услугу с единой ответственностью за результат</p>
      <div class="grid g4">
        {why.map(([n,t,d]) => (
          <div class="card"><div class="n">{n}</div><h3 style="font-size:18px;">{t}</h3><p>{d}</p></div>
        ))}
      </div>
      <div style="margin-top:46px;"><CtaBand /></div>
    </div>
  </section>

</Base>
