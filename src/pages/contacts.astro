---
import Base from '../layouts/Base.astro';
import PageHead from '../components/PageHead.astro';
---
<Base title="Контакты" description="Свяжитесь с DronWay: получите расчёт по вашей задаче, подбор борта и предложение под ключ" active="">
  <PageHead eyebrow="Контакты" title="Получить расчёт"
    lead="Опишите задачу: что нужно возить, снимать или обследовать. Подберём борт, посчитаем экономику и вернёмся с предложением под ключ"
    crumbs={[{label:'Контакты'}]} />
  <section class="sec dark">
    <div class="wrap">
      <div class="detail" style="align-items:start;">
        <div>
          <div class="eyebrow" style="color:#6BA0FF;">Оставьте заявку</div>
          <h2 class="h" style="font-size:28px;">Ответим и предложим решение</h2>
          <form class="form" id="leadForm">
            <input type="text" name="name" placeholder="Как к вам обращаться" required />
            <input type="text" name="company" placeholder="Компания" />
            <input type="text" name="contact" placeholder="Телефон или мессенджер для связи" required />
            <textarea name="task" rows="5" placeholder="Коротко о задаче: что нужно доставлять или обследовать, объект, расстояние, частота рейсов"></textarea>
            <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off" />
            <button type="submit" class="btn lg" id="leadBtn">Отправить заявку</button>
            <div class="note" id="leadNote">Нажимая кнопку, вы соглашаетесь на обработку контактов для ответа на заявку</div>
          </form>
        </div>
        <div>
          <div class="spec" style="background:#1C2127;border-color:#2B313A;padding:24px;">
            <div class="eyebrow" style="color:#6BA0FF;">Прямой контакт</div>
            <p style="color:#C2CAD6;font-size:15px;margin-top:12px;line-height:1.6;">Сайт: dronway.com<br/>Заявки попадают сразу в наш Telegram, отвечаем быстро</p>
          </div>
          <div class="spec" style="background:#1C2127;border-color:#2B313A;padding:24px;margin-top:16px;">
            <div class="eyebrow" style="color:#6BA0FF;">Что будет дальше</div>
            <ul class="flist" style="margin-top:12px;">
              <li style="color:#C2CAD6;">Свяжемся и уточним детали задачи</li>
              <li style="color:#C2CAD6;">Подберём тип борта и модель</li>
              <li style="color:#C2CAD6;">Посчитаем стоимость и сроки</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  <script>
    const f = document.getElementById('leadForm');
    const note = document.getElementById('leadNote');
    const btn = document.getElementById('leadBtn');
    if (f) f.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (f.website && f.website.value) return;
      btn.disabled = true; btn.textContent = 'Отправляем...';
      const data = Object.fromEntries(new FormData(f).entries());
      try {
        const r = await fetch('/api/lead', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data) });
        if (r.ok) { f.reset(); btn.textContent = 'Заявка отправлена'; note.textContent = 'Спасибо, мы получили заявку и скоро свяжемся'; }
        else { btn.disabled = false; btn.textContent = 'Отправить заявку'; note.textContent = 'Не удалось отправить, напишите нам в Telegram'; }
      } catch (err) {
        btn.disabled = false; btn.textContent = 'Отправить заявку'; note.textContent = 'Сеть недоступна, попробуйте ещё раз';
      }
    });
  </script>
</Base>
