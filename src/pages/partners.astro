---
import Base from '../layouts/Base.astro';
import PageHead from '../components/PageHead.astro';
import CtaBand from '../components/CtaBand.astro';
const cards = [
  ['РЕФЕРАЛ','Приводите клиентов','Рекомендуете нас и получаете вознаграждение за каждого клиента, который пришёл по вам'],
  ['РЕГИОН','Развиваете территорию','Берёте регион и работаете с делением выручки на нашей инфраструктуре и продукте'],
  ['ДИЛЕР','Покупаете на спеццене','Берёте борта на специальных условиях для перепродажи и собственного сервиса'],
];
---
<Base title="Партнёрам" description="Партнёрская программа DronWay: реферал, региональное партнёрство с делением выручки, дилерские спеццены" active="/partners">
  <PageHead eyebrow="Партнёрам" title="Зарабатывайте на нашей инфраструктуре и продукте"
    lead="Открыты к партнёрам и агентам. Берите ровно ту модель, что вам ближе, мы даём продукт, документы, обучение и поддержку"
    crumbs={[{label:'Партнёрам'}]} />
  <section class="sec white">
    <div class="wrap">
      <div class="grid g3" style="margin-top:0;">
        {cards.map(([n,t,d]) => (<div class="card"><div class="n">{n}</div><h3>{t}</h3><p>{d}</p></div>))}
      </div>
      <div style="margin-top:46px;"><CtaBand title="Стать партнёром" text="Расскажите про себя и регион, обсудим условия и формат сотрудничества" cta="Оставить заявку" /></div>
    </div>
  </section>
</Base>
