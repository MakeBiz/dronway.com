---
import Base from '../layouts/Base.astro';
import PageHead from '../components/PageHead.astro';
import CtaBand from '../components/CtaBand.astro';
const cards = [
  ['Аренда с экипажем','Борт и обученный пилот приезжают на ваш объект, вам не нужен свой парк'],
  ['Оплата за вылет','Платите за результат: за вылет, за гектар или регулярной подпиской под маршрут'],
  ['SLA и отклик','Гарантированное время реакции на заявку, фиксируем в договоре'],
  ['Подменный фонд','Борт на замену, чтобы работа не вставала из-за ремонта или ТО'],
  ['Без сертификата','Регуляторику и сертификат эксплуатанта держим мы или партнёр-эксплуатант'],
  ['Прозрачная цена','Считаем стоимость и окупаемость маршрута заранее, без скрытых платежей'],
];
---
<Base title="Дрон как сервис" description="Дрон как сервис от DronWay: без своего сертификата и пилота, оплата за результат, SLA и подменный фонд" active="">
  <PageHead eyebrow="Дрон как сервис" title="Вам не нужен ни сертификат, ни пилот"
    lead="По сервисной модели всю регуляторику и эксплуатацию держим мы или наш партнёр-эксплуатант. Вы платите за результат, а не за владение техникой"
    crumbs={[{label:'Дрон как сервис'}]} />
  <section class="sec white">
    <div class="wrap">
      <div class="grid g3" style="margin-top:0;">
        {cards.map(([t,d]) => (<div class="card"><h3 style="font-size:19px;">{t}</h3><p>{d}</p></div>))}
      </div>
      <div style="margin-top:46px;"><CtaBand title="Посчитать сервис под ваш маршрут" text="Опишите задачу и частоту, посчитаем стоимость вылета и подписки" /></div>
    </div>
  </section>
</Base>
