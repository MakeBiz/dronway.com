---
import Base from '../../layouts/Base.astro';
import PageHead from '../../components/PageHead.astro';
import { drones, platform } from '../../data/drones.js';

export function getStaticPaths() {
  return drones.map((d) => ({ params: { slug: d.slug }, props: { d } }));
}
const { d } = Astro.props;
const klassLabel = d.klass === 'light' ? 'Лёгкий, учёт' : 'Тяжёлый, госрегистрация + СЛГ';
const docsLabel  = d.klass === 'light' ? 'Учёт через Госуслуги, СЛГ не нужен' : 'Госрегистрация, СЛГ, сертификат эксплуатанта';
const others = drones.filter((x) => x.slug !== d.slug);
---
<Base
  title={d.name}
  description={`${d.name} DronWay: нагрузка ${d.payload} кг, полёт ${d.flight} мин. ${d.tagline}`}
  active="/catalog"
>
  <PageHead
    eyebrow={`Грузовой дрон · ${d.frame}`}
    title={d.name}
    lead={d.tagline}
    crumbs={[{label:'Каталог', href:'/catalog'}, {label:d.name}]}
  />

  <!-- Полоса ключевых цифр -->
  <div class="specband">
    <div class="wrap specband-inner">
      <div class="sb-item">
        <span class="sb-num">{d.payload}</span>
        <span class="sb-unit">кг</span>
        <span class="sb-label">макс. нагрузка</span>
      </div>
      <div class="sb-div"></div>
      <div class="sb-item">
        <span class="sb-num">{d.flight}</span>
        <span class="sb-unit">мин</span>
        <span class="sb-label">макс. полёт</span>
      </div>
      <div class="sb-div"></div>
      {d.range_max ? (
        <>
          <div class="sb-item">
            <span class="sb-num">{d.range_max}</span>
            <span class="sb-unit">км</span>
            <span class="sb-label">без нагрузки</span>
          </div>
          <div class="sb-div"></div>
        </>
      ) : null}
      {d.speed_max ? (
        <div class="sb-item">
          <span class="sb-num">{d.speed_max}</span>
          <span class="sb-unit">км/ч</span>
          <span class="sb-label">макс. скорость</span>
        </div>
      ) : (
        <div class="sb-item">
          <span class="sb-num">—</span>
          <span class="sb-label">скорость уточняется</span>
        </div>
      )}
      <div class="sb-div"></div>
      <div class="sb-item">
        <span class="sb-num sb-klass">{d.klass === 'light' ? 'Лёгкий' : 'Тяжёлый'}</span>
        <span class="sb-label">класс по документам</span>
      </div>
    </div>
  </div>

  <section class="sec white">
    <div class="wrap">
      <div class="detail">

        <!-- Левая: описание и таблица дальности -->
        <div>
          <p class="mod-desc">{d.desc}</p>

          {d.delivery.length > 0 && (
            <div class="delivery-block">
              <div class="eyebrow" style="margin-bottom:14px;">Дальность доставки туда-обратно</div>
              <table class="dtable">
                <thead>
                  <tr>
                    <th>Нагрузка</th>
                    <th>Дальность с возвратом</th>
                    <th>Примечание</th>
                  </tr>
                </thead>
                <tbody>
                  {d.delivery.map((row) => (
                    <tr>
                      <td><strong>{row.load} кг</strong></td>
                      <td><span class="range-num">{row.range} км</span></td>
                      <td class="td-note">{row.note}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
              <p class="table-note">Дальность — расстояние до точки с возвратом на базу. При наличии зарядки на точке доставки плечо увеличивается согласно столбцу "Примечание"</p>
            </div>
          )}

          <div class="eyebrow" style="margin-top:36px;margin-bottom:14px;">Функционал и особенности</div>
          <ul class="flist">
            {d.features.map((f) => (<li>{f}</li>))}
          </ul>

          <div class="eyebrow" style="margin-top:30px;margin-bottom:14px;">Под какие задачи</div>
          <div class="chips">
            {d.tasks.map((t) => (<span>{t}</span>))}
          </div>
        </div>

        <!-- Правая: таблица технических характеристик -->
        <div>
          <div class="spec-title">Технические характеристики</div>
          <div class="spec">
            <div class="row"><span class="k">Максимальная нагрузка</span><span class="v blue">{d.payload} кг</span></div>
            <div class="row"><span class="k">Макс. время полёта</span><span class="v">{d.flight} мин</span></div>
            {d.range_max && <div class="row"><span class="k">Дальность без нагрузки</span><span class="v">{d.range_max} км</span></div>}
            {d.speed_max && <div class="row"><span class="k">Макс. скорость</span><span class="v">{d.speed_max} км/ч</span></div>}
            <div class="row"><span class="k">Схема</span><span class="v">{d.frame}</span></div>
            <div class="row"><span class="k">Класс по массе</span><span class="v">{klassLabel}</span></div>
            <div class="row"><span class="k">Взлёт и посадка</span><span class="v">Вертикальные, VTOL</span></div>
          </div>

          <div class="spec-title" style="margin-top:20px;">Навигация и связь</div>
          <div class="spec">
            <div class="row"><span class="k">ГНСС</span><span class="v">{platform.nav.join(', ')}</span></div>
            <div class="row"><span class="k">Защита от спуфинга</span><span class="v">{platform.protection}</span></div>
            <div class="row"><span class="k">RTK</span><span class="v">{platform.rtk}</span></div>
            <div class="row"><span class="k">Связь и управление</span><span class="v">{platform.comms}</span></div>
            <div class="row"><span class="k">Видео</span><span class="v">{platform.video}</span></div>
          </div>

          <div class="spec-title" style="margin-top:20px;">Надёжность</div>
          <div class="spec">
            <div class="row"><span class="k">Автопилот</span><span class="v">{platform.autopilot}</span></div>
            <div class="row"><span class="k">Корпус</span><span class="v">{platform.body}</span></div>
          </div>

          <div class="spec-title" style="margin-top:20px;">Документы</div>
          <div class="spec">
            <div class="row"><span class="k">Путь легализации</span><span class="v">{docsLabel}</span></div>
            <div class="row"><span class="k">Кто оформляет</span><span class="v">DronWay берёт на себя</span></div>
          </div>

          <div class="spec-title" style="margin-top:20px;">Опции</div>
          <div class="chips" style="margin-top:10px;margin-bottom:24px;">
            {d.options.map((o) => (<span>{o}</span>))}
          </div>

          <a href="/contacts" class="btn lg" style="width:100%;">Запросить расчёт и КП</a>
          <a href="/daas" class="btn lg ghost" style="margin-top:10px;width:100%;color:var(--ink);border-color:var(--line);">Взять как сервис</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Сравнение линейки -->
  <section class="sec">
    <div class="wrap">
      <div class="eyebrow">Линейка</div>
      <h2 class="h" style="font-size:28px;">Сравните с другими бортами</h2>
      <div class="lineup-table-wrap">
        <table class="lineup-table">
          <thead>
            <tr>
              <th>Модель</th>
              <th>Схема</th>
              <th>Нагрузка</th>
              <th>Полёт</th>
              <th>Дальность б/н</th>
              <th>Скорость</th>
              <th>Класс</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {drones.map((row) => (
              <tr class={row.slug === d.slug ? 'row-current' : ''}>
                <td><strong>{row.name}</strong></td>
                <td>{row.frame}</td>
                <td class={row.slug === d.slug ? 'td-blue' : ''}>{row.payload} кг</td>
                <td>{row.flight} мин</td>
                <td>{row.range_max ? `${row.range_max} км` : '—'}</td>
                <td>{row.speed_max ? `${row.speed_max} км/ч` : '—'}</td>
                <td>{row.klass === 'light' ? 'Лёгкий' : 'Тяжёлый'}</td>
                <td>
                  {row.slug !== d.slug
                    ? <a href={`/catalog/${row.slug}`} class="tbl-link">→</a>
                    : <span class="tbl-current">текущий</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

</Base>

<style>
/* полоса ключевых цифр */
.specband { background: var(--ink); border-bottom: 1px solid #2B313A; padding: 28px 0; }
.specband-inner { display: flex; align-items: center; gap: 0; flex-wrap: wrap; }
.sb-item { display: flex; flex-direction: column; align-items: center; padding: 0 28px; }
.sb-div { width: 1px; height: 48px; background: #2B313A; flex-shrink: 0; }
.sb-num { font-family: 'Montserrat', sans-serif; font-size: 36px; font-weight: 800; color: #fff; line-height: 1; }
.sb-unit { font-size: 13px; color: var(--blue); font-weight: 700; letter-spacing: 1px; margin-top: 2px; }
.sb-label { font-size: 11px; color: #697483; letter-spacing: .5px; margin-top: 4px; }
.sb-klass { font-size: 20px; }

/* описание модели */
.mod-desc { font-size: 16px; color: var(--muted); line-height: 1.65; margin-bottom: 30px; }

/* таблица дальности */
.delivery-block { margin-bottom: 8px; }
.dtable { width: 100%; border-collapse: collapse; font-size: 15px; }
.dtable th { text-align: left; font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); padding: 8px 12px; border-bottom: 2px solid var(--line); }
.dtable td { padding: 12px; border-bottom: 1px solid var(--line); vertical-align: middle; }
.dtable tr:last-child td { border-bottom: none; }
.range-num { font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 17px; color: var(--blue); }
.td-note { font-size: 13px; color: var(--muted); }
.table-note { font-size: 12px; color: var(--muted); margin-top: 10px; line-height: 1.5; }

/* заголовки таблиц справа */
.spec-title { font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--blue); margin-bottom: 8px; }

/* сравнительная таблица линейки */
.lineup-table-wrap { overflow-x: auto; margin-top: 30px; }
.lineup-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.lineup-table th { text-align: left; font-family: 'Montserrat', sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); padding: 10px 14px; border-bottom: 2px solid var(--line); white-space: nowrap; }
.lineup-table td { padding: 12px 14px; border-bottom: 1px solid var(--line); }
.row-current td { background: #EAF1FE; }
.row-current td:first-child { font-weight: 700; color: var(--blue); }
.td-blue { color: var(--blue); font-family: 'Montserrat', sans-serif; font-weight: 700; }
.tbl-link { color: var(--blue); font-weight: 700; font-size: 16px; }
.tbl-current { font-size: 11px; color: var(--blue); font-family: 'Montserrat', sans-serif; font-weight: 700; letter-spacing: 1px; }

@media (max-width: 680px) {
  .specband-inner { gap: 10px; }
  .sb-item { padding: 0 14px; }
  .sb-num { font-size: 28px; }
}
</style>
